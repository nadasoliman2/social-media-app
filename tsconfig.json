{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "target": "ES2023",
    "moduleResolution": "NodeNext",

    "strict": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "src/api/**/*"],
  "exclude": ["node_modules", "dist"]
}